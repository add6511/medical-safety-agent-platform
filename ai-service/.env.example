# 基层医疗安全型预问诊AI服务 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 应用配置
APP_NAME=基层医疗安全型预问诊AI服务
APP_VERSION=0.1.0
APP_ENV=development
LOG_LEVEL=INFO

# AI 模式：mock（模拟）/ real（真实调用）
AI_MODE=mock

# 模型配置（真实模式下需要填写）
MODEL_BASE_URL=
MODEL_API_KEY=
MODEL_NAME=

# 数据库配置
DATABASE_URL=

# CORS 允许的前端地址（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
