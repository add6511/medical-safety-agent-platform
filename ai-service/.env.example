# 基层医疗安全型预问诊AI服务 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 应用配置
APP_NAME=基层医疗安全型预问诊AI服务
APP_VERSION=0.1.0
APP_ENV=development
LOG_LEVEL=INFO

# AI 模式：mock（模拟）/ real（真实调用）
AI_MODE=mock

# 模型配置（真实模式下需要填写）
MODEL_BASE_URL=
MODEL_API_KEY=
MODEL_NAME=

# 数据库配置
DATABASE_URL=

# CORS 允许的前端地址（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===== RAG 相关配置 =====

# 向量存储模式：memory（内存）或 pgvector（PostgreSQL）
VECTOR_STORE_MODE=memory

# Embedding 模式：mock（本地模拟）或 openai_compatible（调用兼容接口）
EMBEDDING_MODE=mock

# Embedding 向量维度
EMBEDDING_DIMENSION=384

# 文档切分参数
CHUNK_SIZE=500
CHUNK_OVERLAP=80

# pgvector 数据库连接（pgvector 模式下需要填写）
VECTOR_DATABASE_URL=

# Embedding 接口配置（openai_compatible 模式下需要填写）
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=

# ===== Agent 相关配置 =====

# Agent 模式：mock（模拟）/ real（真实模型）
AGENT_MODE=mock

# 安全规则集版本
SAFETY_RULESET_VERSION=synthetic-1.0.0

# 模型版本标识
MODEL_VERSION=mock-medical-agent-v1

# Prompt 版本标识
PROMPT_VERSION=preconsultation-v1

# 是否启用模型风险建议
ENABLE_MODEL_RISK_SUGGESTION=true
